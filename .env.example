# Copy only the variables required by the services you use. Keep values empty in Git.
# No AutoMem architecture or automem-runtime-v1 behavior is configurable here.

# OpenAI-compatible task/model service. Both endpoint spellings are retained because
# the benchmark and multimedia adapters currently consume different conventional names.
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_BASE_URL=

# Optional task endpoint override used by the GAIA runner. A role-specific base
# must be paired with its matching key; AutoMem will not reuse the generic key.
TASK_API_KEY=
TASK_API_BASE=

# Optional independent evaluator endpoint. Set the key and base together.
JUDGE_API_KEY=
JUDGE_API_BASE=

# Optional independent architecture-search and diagnosis endpoints. Set each
# role-specific key/base pair together.
SEARCH_API_KEY=
SEARCH_API_BASE=
DIAGNOSIS_API_KEY=
DIAGNOSIS_API_BASE=

# Optional service-role model defaults. Prefer explicit CLI model arguments when
# the selected entrypoint exposes them.
DEFAULT_MODEL=
DEFAULT_JUDGE_MODEL=
SEARCH_MODEL=
DIAGNOSIS_MODEL=

# Web, page-reader, repository, and multimedia tools.
SERPER_API_KEY=
SERPER_API_KEYS=
JINA_API_KEY=
JINA_API_BASE=
GITHUB_TOKEN=
MTU_API_KEY=
MTU_BASE_URL=

# Evidence-provider selection. Defaults are shown explicitly here because
# changing either provider changes benchmark behavior and the protocol digest.
WEB_SEARCH_PROVIDER=serper
WEB_ACCESS_PROVIDER=jina

# Optional network proxy for page crawling.
CRAWL_PROXY=

# Optional persistent web/page cache location. Defaults to the platform user cache.
AUTOMEM_CACHE_DIR=
ENABLE_SEARCH_CACHE=true
ENABLE_PAGE_CACHE=true
CACHE_TTL_DAYS=
SEARCH_CACHE_TTL_DAYS=
PAGE_CACHE_TTL_DAYS=
FREEZE_CACHE=false

# Some compatible model services require streaming. This affects task/judge
# behavior and is signed into the evaluation protocol.
FORCE_STREAM=false
TASK_TOKEN_CAP=
